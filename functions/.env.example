# Copy this file to .env and fill in your values
# NEVER commit .env to source control

# ──────────────────────────────────────────────────────────────────────────────
# REQUIRED: Your Gemini API key from https://aistudio.google.com/app/apikey
# ──────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL: Set to "true" to skip real Gemini calls and use demo extraction.
# Use this for local testing without a valid Gemini API key.
# ──────────────────────────────────────────────────────────────────────────────
DEMO_MODE=false

# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL: Demo password used when seeding demo accounts.
# ──────────────────────────────────────────────────────────────────────────────
DEMO_PASSWORD=BuildVox2024!
